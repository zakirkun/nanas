# Base URL of the Nanas API. Leave empty to use same-origin (production embed
# or the Vite dev proxy). Set this only when the SPA is hosted separately
# from the API and CORS is configured on the backend.
VITE_API_BASE_URL=

# Used by the Vite dev server to proxy /v1, /auth, /admin, /fn, /internal
# during development. Defaults to http://localhost:8080 if unset.
VITE_API_PROXY_TARGET=http://localhost:8080

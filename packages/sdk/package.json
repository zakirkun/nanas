{
  "name": "@nanas/sdk",
  "version": "0.1.0",
  "description": "TypeScript client for the Nanas control plane HTTP API.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "generate": "tsx scripts/gen-types.ts",
    "build": "pnpm run generate && tsc -p tsconfig.build.json",
    "prepack": "pnpm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "openapi-typescript": "^7.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "license": "MIT"
}
